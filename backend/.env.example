# Required: Django will not start without OLYMPY_SECRET_KEY.
OLYMPY_SECRET_KEY=dev-only-change-me
OLYMPY_DEBUG=1
OLYMPY_ALLOWED_HOSTS=localhost,127.0.0.1
# Production: ushbu ro'yxatga aniq domeningizni qo'shing. Bo'sh qoldirilmasin —
# CORS_ALLOW_ALL_ORIGINS doimiy ravishda False, faqat shu originlar so'rovi qabul qilinadi.
OLYMPY_CORS_ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:5173,http://127.0.0.1:5173

# SQLite is used by default. Set OLYMPY_DB_ENGINE=postgres to use PostgreSQL.
OLYMPY_DB_ENGINE=sqlite
OLYMPY_DB_NAME=olympy
OLYMPY_DB_USER=olympy
OLYMPY_DB_PASSWORD=
OLYMPY_DB_HOST=localhost
OLYMPY_DB_PORT=5432

# Telegram phone verification
# Get a token from @BotFather (https://t.me/BotFather), set TELEGRAM_BOT_USERNAME
# to the bot's @handle (without the @). Leave both blank to run in mock mode — the
# backend will log the messages it would have sent without calling Telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# OTP lifetime (seconds); default 5 minutes.
PHONE_VERIFICATION_OTP_TTL_SECONDS=300
# Maximum wrong-OTP attempts before the session is blocked.
PHONE_VERIFICATION_MAX_ATTEMPTS=5
