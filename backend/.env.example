# Required: Django will not start without OLYMPY_SECRET_KEY.
# Production: generate a long random value and keep it secret.
OLYMPY_SECRET_KEY=your_secret_key_here
# Production'da DOIM False. True faqat lokal development uchun. Default ham
# False — bu o'zgaruvchi o'rnatilmasa ham xavfsiz holatda qoladi.
OLYMPY_DEBUG=False
# Required in production. Use comma-separated hostnames, e.g. yourdomain.com,www.yourdomain.com.
OLYMPY_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# Production: ushbu ro'yxatga aniq domeningizni qo'shing. Bo'sh qoldirilmasin —
# CORS_ALLOW_ALL_ORIGINS doimiy ravishda False, faqat shu originlar so'rovi qabul qilinadi.
OLYMPY_CORS_ALLOWED_ORIGINS=https://yourdomain.com
OLYMPY_CSRF_TRUSTED_ORIGINS=https://yourdomain.com
OLYMPY_SECURE_SSL_REDIRECT=1
OLYMPY_SECURE_HSTS_SECONDS=31536000
PROFILE_IMAGE_MAX_BYTES=5242880
CENTER_IMAGE_MAX_BYTES=5242880

# PostgreSQL is recommended in production. DATABASE_URL takes precedence
# if your host provides it, e.g. postgres://user:pass@host:5432/dbname.
DATABASE_URL=
OLYMPY_DB_ENGINE=postgres
OLYMPY_DB_NAME=olympy
OLYMPY_DB_USER=olympy
OLYMPY_DB_PASSWORD=
OLYMPY_DB_HOST=localhost
OLYMPY_DB_PORT=5432

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0

# Media storage (Cloudinary). Render diski persistent emas — production'da
# yuklangan rasmlar (avatar, markaz logosi) har deploy'da yo'qolmasligi uchun
# Cloudinary (bepul tier) ishlatiladi. CLOUDINARY_CLOUD_NAME o'rnatilsa media
# fayllar avtomatik Cloudinary'da saqlanadi; bo'sh qoldirilsa lokal diskda.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Telegram bots
# Get tokens from @BotFather (https://t.me/BotFather). The auth bot sends
# phone verification codes. The manager bot sends notifications and handles
# inline approval callbacks. TELEGRAM_BOT_* is a backward-compatible fallback.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_AUTH_BOT_TOKEN=
TELEGRAM_AUTH_BOT_USERNAME=
TELEGRAM_MANAGER_BOT_TOKEN=
TELEGRAM_MANAGER_BOT_USERNAME=
# Optional but recommended in production. Must match Telegram setWebhook secret_token.
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_AUTH_WEBHOOK_SECRET=
TELEGRAM_MANAGER_WEBHOOK_SECRET=
# OTP lifetime (seconds); default 5 minutes.
PHONE_VERIFICATION_OTP_TTL_SECONDS=300
# Maximum wrong-OTP attempts before the session is blocked.
PHONE_VERIFICATION_MAX_ATTEMPTS=5

# Optional: AI roster approval from Telegram text/photos. AI extracts names;
# backend permissions and strict matching perform the approval.
OPENAI_API_KEY=
# Optional fallback list. The backend tries keys from left to right.
AI_ROSTER_OPENAI_API_KEYS=
AI_ROSTER_MODEL=gpt-4o-mini
GEMINI_API_KEY=
# Optional fallback list. Used after OpenAI keys fail or when OpenAI is absent.
AI_ROSTER_GEMINI_API_KEYS=
AI_ROSTER_GEMINI_MODEL=gemini-2.5-flash
# Xavfsizlik: default False. True qilinsa AI ajratgan ismlar inson
# tasdig'isiz avtomatik qabul qilinadi — faqat ishonchli muhitda yoqing.
AI_ROSTER_AUTO_APPROVE=False
AI_ROSTER_ALLOW_NAME_ONLY_APPROVAL=1
AI_ROSTER_MIN_CONFIDENCE=0.98
AI_ROSTER_MAX_NAMES=200
AI_ROSTER_MAX_IMAGE_BYTES=5242880
AI_MANAGER_BOT_MAX_DOCUMENT_BYTES=10485760
AI_MANAGER_BOT_OPENAI_API_KEY=
AI_MANAGER_BOT_OPENAI_API_KEYS=
AI_MANAGER_BOT_MODEL=gpt-4o-mini
AI_MANAGER_BOT_TEMPERATURE=0.45
AI_MANAGER_BOT_GEMINI_API_KEY=
AI_MANAGER_BOT_GEMINI_API_KEYS=
AI_MANAGER_BOT_GEMINI_MODEL=gemini-2.5-flash
AI_MANAGER_BOT_GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-flash-lite-latest,gemini-flash-latest,gemini-3-flash-preview,gemini-3-pro-preview,gemini-3.1-pro-preview,gemini-3.1-flash-lite-preview,gemini-2.5-pro,gemini-pro-latest,gemini-2.0-flash,gemini-2.0-flash-001,gemini-2.0-flash-lite,gemini-2.0-flash-lite-001
AI_MANAGER_BOT_GEMINI_AUTO_DISCOVER_MODELS=1
AI_MANAGER_BOT_GEMINI_MODEL_CACHE_SECONDS=21600
AI_MANAGER_BOT_GEMINI_MAX_MODELS=40
AI_MANAGER_BOT_MEMORY_ENABLED=1
AI_MANAGER_BOT_MEMORY_TTL_SECONDS=21600
AI_MANAGER_BOT_HISTORY_MESSAGES=8

# AI question generation in manager/teacher/owner question creator.
# Keep this separate if you want a different OpenAI key for generated tests.
AI_QUESTION_OPENAI_API_KEY=
# Optional fallback list. The backend tries keys from left to right.
AI_QUESTION_OPENAI_API_KEYS=
AI_QUESTION_MODEL=gpt-4o-mini
AI_QUESTION_GEMINI_API_KEY=
AI_QUESTION_GEMINI_API_KEYS=
AI_QUESTION_GEMINI_MODEL=gemini-2.5-flash
AI_QUESTION_MAX_COUNT=30
AI_QUESTION_MAX_OUTPUT_TOKENS=6000
AI_QUESTION_PDF_MAX_BYTES=20971520
AI_QUESTION_PDF_MAX_TEXT_CHARS=120000

# ─── To'lov tizimi (billing) ─────────────────────────────────────────────────
# Payme (O'zbekiston). Ikkala qiymat ham o'rnatilsa PAYME_ENABLED=True bo'ladi
# va checkout/webhook ishlaydi. Bo'sh qoldirilsa Payme o'chiq (checkout 503
# qaytaradi) — kod sinmaydi. Merchant ID va kalit Payme kabinetidan olinadi.
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
# Click (O'zbekiston). Uchala qiymat ham o'rnatilsa CLICK_ENABLED=True bo'ladi.
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
# Muvaffaqiyatli to'lovdan menejerga hisoblanadigan komissiya ulushi (0.20=20%).
MANAGER_COMMISSION_RATE=0.20
# Bepul rejimda markaz oyiga maksimal nechta olimpiada yarata oladi.
FREE_OLYMPIAD_MONTHLY_LIMIT=2
# To'lovda muammo bo'lganda foydalanuvchiga ko'rsatiladigan support kontakti.
OLYMPY_SUPPORT_CONTACT=
